# Скопируйте в .env и заполните значения.
# В продакшене обязательно задайте SECRET_KEY и DEBUG=0.

# Секретный ключ Django (сгенерируйте свой: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=your-secret-key-here

# Режим отладки: True для разработки, False для продакшена
DJANGO_DEBUG=True

# Разрешённые хосты через запятую (для продакшена: yourdomain.com,www.yourdomain.com)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Ключ для AI-помощника по урокам (Gemini). Получить: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
